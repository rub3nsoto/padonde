# ──────────────────────────────────────────
# EVENTURE — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ──────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/eventure?schema=public"

# Clerk — Auth (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/registro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/explorar
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/registro?step=perfil

# Mapbox — Mapas (https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoixxxxxx

# Cloudinary — Storage de media (https://cloudinary.com)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx
CLOUDINARY_UPLOAD_PRESET=eventure_unsigned

# Stripe — Pagos (https://dashboard.stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Email — Nodemailer (usar Gmail App Password o servicio SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM="Eventure <noreply@eventure.mx>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
